<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:KaraokeApp.Converters;assembly=KaraokeApp">

    <!-- ── CONVERTERS ── -->
    <conv:BoolToVisibilityConverter        x:Key="BoolToVisibility"/>
    <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    <conv:BoolToOnOffConverter             x:Key="BoolToOnOff"/>
    <conv:PitchToStringConverter           x:Key="PitchToString"/>

    <!-- ══════════════════════════════════════════════════════════
         DARK KARAOKE COLOR PALETTE
         ══════════════════════════════════════════════════════════ -->
    <Color x:Key="C_BgDeep"     >#080D1A</Color>
    <Color x:Key="C_BgApp"      >#0A0F1E</Color>
    <Color x:Key="C_BgPanel"    >#0D1626</Color>
    <Color x:Key="C_BgSurface"  >#111E35</Color>
    <Color x:Key="C_BgHeader"   >#0F1A30</Color>
    <Color x:Key="C_BgCtrl"     >#060C18</Color>
    <Color x:Key="C_Border"     >#1E3A5F</Color>
    <Color x:Key="C_BorderLight">#2A5080</Color>
    <!-- Accent Cyan -->
    <Color x:Key="C_Cyan"       >#22D3EE</Color>
    <Color x:Key="C_CyanDim"    >#0E7490</Color>
    <Color x:Key="C_CyanDark"   >#083344</Color>
    <!-- Accent Purple -->
    <Color x:Key="C_Purple"     >#818CF8</Color>
    <Color x:Key="C_PurpleDark" >#3730A3</Color>
    <!-- Active / Playing Gold -->
    <Color x:Key="C_Gold"       >#FBBF24</Color>
    <Color x:Key="C_GoldDark"   >#78350F</Color>
    <!-- Play Green -->
    <Color x:Key="C_Green"      >#22C55E</Color>
    <Color x:Key="C_GreenDark"  >#14532D</Color>
    <Color x:Key="C_GreenHover" >#16A34A</Color>
    <!-- Danger Red -->
    <Color x:Key="C_Red"        >#F87171</Color>
    <Color x:Key="C_RedDark"    >#7F1D1D</Color>
    <!-- Text -->
    <Color x:Key="C_TextPrimary">#F8FAFC</Color>
    <Color x:Key="C_TextSecond" >#94A3B8</Color>
    <Color x:Key="C_TextDim"    >#475569</Color>
    <!-- Button states -->
    <Color x:Key="C_BtnNormal"  >#1E293B</Color>
    <Color x:Key="C_BtnHover"   >#2D3F5F</Color>
    <Color x:Key="C_BtnPress"   >#0F1929</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="AppBg"          Color="{StaticResource C_BgApp}"/>
    <SolidColorBrush x:Key="PanelBg"        Color="{StaticResource C_BgPanel}"/>
    <SolidColorBrush x:Key="SurfaceBg"      Color="{StaticResource C_BgSurface}"/>
    <SolidColorBrush x:Key="HeaderBg"       Color="{StaticResource C_BgHeader}"/>
    <SolidColorBrush x:Key="CtrlBarBg"      Color="{StaticResource C_BgCtrl}"/>
    <SolidColorBrush x:Key="BorderBrush"    Color="{StaticResource C_Border}"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource C_BorderLight}"/>
    <SolidColorBrush x:Key="CyanBrush"      Color="{StaticResource C_Cyan}"/>
    <SolidColorBrush x:Key="PurpleBrush"    Color="{StaticResource C_Purple}"/>
    <SolidColorBrush x:Key="GoldBrush"      Color="{StaticResource C_Gold}"/>
    <SolidColorBrush x:Key="GreenBrush"     Color="{StaticResource C_Green}"/>
    <SolidColorBrush x:Key="RedBrush"       Color="{StaticResource C_Red}"/>
    <SolidColorBrush x:Key="TextPrimary"    Color="{StaticResource C_TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondary"  Color="{StaticResource C_TextSecond}"/>
    <SolidColorBrush x:Key="TextDim"        Color="{StaticResource C_TextDim}"/>

    <!-- Gradient Brushes -->
    <LinearGradientBrush x:Key="AppGradientBg" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#080D1A" Offset="0"/>
        <GradientStop Color="#0F1A35" Offset="0.5"/>
        <GradientStop Color="#14103A" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CyanGlowBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#22D3EE" Offset="0"/>
        <GradientStop Color="#818CF8" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="NowPlayingBg" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#0D0D2A" Offset="0"/>
        <GradientStop Color="#0A1F3D" Offset="0.5"/>
        <GradientStop Color="#0D0D2A" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="PlayBtnBg" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#22C55E" Offset="0"/>
        <GradientStop Color="#16A34A" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CtrlBtnBg" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#1E293B" Offset="0"/>
        <GradientStop Color="#0F172A" Offset="1"/>
    </LinearGradientBrush>

    <!-- Font -->
    <FontFamily x:Key="AppFont">Segoe UI</FontFamily>

    <!-- ══════════════════════════════════════════════════════════
         BASE BUTTON — Dark, glowing hover, scale-press
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="BaseBtn" TargetType="ButtonBase">
        <Setter Property="FontFamily"        Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"          Value="12"/>
        <Setter Property="FontWeight"        Value="Bold"/>
        <Setter Property="Foreground"        Value="{StaticResource TextPrimary}"/>
        <Setter Property="BorderBrush"       Value="{StaticResource BorderBrush}"/>
        <Setter Property="BorderThickness"   Value="1"/>
        <Setter Property="Padding"           Value="10,6"/>
        <Setter Property="MinHeight"         Value="38"/>
        <Setter Property="Cursor"            Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ButtonBase">
                    <Border x:Name="bd"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.Background>
                            <SolidColorBrush x:Name="bdBg" Color="{StaticResource C_BtnNormal}"/>
                        </Border.Background>
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="bdScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect x:Name="bdGlow" Color="#22D3EE"
                                              ShadowDepth="0" BlurRadius="0" Opacity="0"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover: glow in + background brighten -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bdBg"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{StaticResource C_BtnHover}"
                                                        Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="bdGlow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="12" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="bdGlow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.7" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="bdBg"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{StaticResource C_BtnNormal}"
                                                        Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="bdGlow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="bdGlow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <!-- Press: scale down -->
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="bdScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.94" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="bdScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.94" Duration="0:0:0.06"/>
                                        <ColorAnimation Storyboard.TargetName="bdBg"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{StaticResource C_BtnPress}"
                                                        Duration="0:0:0.06"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="bdScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="bdScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Button" BasedOn="{StaticResource BaseBtn}"/>

    <!-- ── TOGGLE BUTTON ── -->
    <Style TargetType="ToggleButton" BasedOn="{StaticResource BaseBtn}">
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
                <Setter Property="Foreground"  Value="{StaticResource CyanBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── CATEGORY / LANGUAGE BUTTON – glowing pill ── -->
    <Style x:Key="CatBtn" TargetType="ToggleButton">
        <Setter Property="FontFamily"      Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontWeight"      Value="Bold"/>
        <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="20,7"/>
        <Setter Property="MinHeight"       Value="36"/>
        <Setter Property="Margin"          Value="5,0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="bd" CornerRadius="18"
                            BorderThickness="1.5"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.Background>
                            <SolidColorBrush x:Name="catBg" Color="#0D1626"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush x:Name="catBorder" Color="{StaticResource C_Border}"/>
                        </Border.BorderBrush>
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="catScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect x:Name="catGlow" Color="#22D3EE"
                                              ShadowDepth="0" BlurRadius="0" Opacity="0"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}">
                            <ContentPresenter.Effect>
                                <DropShadowEffect x:Name="textGlow" Color="#22D3EE"
                                                  ShadowDepth="0" BlurRadius="0" Opacity="0"/>
                            </ContentPresenter.Effect>
                        </ContentPresenter>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- ACTIVE state — use animations (named brushes are not in visual tree) -->
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="catBg"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#083344" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="catBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#22D3EE" Duration="0:0:0"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="catBg"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#0D1626" Duration="0:0:0"/>
                                        <ColorAnimation Storyboard.TargetName="catBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="{StaticResource C_Border}" Duration="0:0:0"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <Setter Property="Foreground" Value="#22D3EE"/>
                        </Trigger>
                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="catBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#22D3EE" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="catGlow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="10" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="catGlow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.5" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="catGlow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="catGlow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <!-- Press -->
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="catScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.93" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="catScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.93" Duration="0:0:0.06"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="catScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="catScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── TAB BUTTON (My Computer / YouTube) ── -->
    <Style x:Key="TabBtn" TargetType="ToggleButton" BasedOn="{StaticResource BaseBtn}">
        <Setter Property="Padding"         Value="16,6"/>
        <Setter Property="FontSize"        Value="11"/>
        <Setter Property="MinHeight"       Value="32"/>
        <Setter Property="Margin"          Value="3,3,0,0"/>
        <Setter Property="BorderThickness" Value="1,1,1,0"/>
        <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
        <Style.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter Property="Foreground"  Value="{StaticResource CyanBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource CyanBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ── NAV SCROLL BUTTON ── -->
    <Style x:Key="NavBtn" TargetType="Button" BasedOn="{StaticResource BaseBtn}">
        <Setter Property="Width"   Value="36"/>
        <Setter Property="Height"  Value="36"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="16"/>
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         KEYBOARD KEY — White on dark, cyan flash on press
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="KbKey" TargetType="Button">
        <Setter Property="FontFamily"  Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"    Value="13"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
        <Setter Property="Width"       Value="42"/>
        <Setter Property="Height"      Value="42"/>
        <Setter Property="Padding"     Value="0"/>
        <Setter Property="Margin"      Value="2.5"/>
        <Setter Property="MinHeight"   Value="42"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="6"
                            BorderThickness="1"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.Background>
                            <SolidColorBrush x:Name="kbBg" Color="#1C2B44"/>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush x:Name="kbBorder" Color="#2A4060"/>
                        </Border.BorderBrush>
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="kbScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect x:Name="kbGlow" Color="#22D3EE"
                                              ShadowDepth="0" BlurRadius="0" Opacity="0"/>
                        </Border.Effect>
                        <TextBlock x:Name="kbText"
                                   Text="{TemplateBinding Content}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextPrimary}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="kbBg"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#243A5E" Duration="0:0:0.1"/>
                                        <ColorAnimation Storyboard.TargetName="kbBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#22D3EE" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="kbBg"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#1C2B44" Duration="0:0:0.15"/>
                                        <ColorAnimation Storyboard.TargetName="kbBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#2A4060" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <!-- Cyan flash on press -->
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="kbScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.88" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetName="kbScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.88" Duration="0:0:0.05"/>
                                        <ColorAnimation Storyboard.TargetName="kbBg"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#083344" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetName="kbGlow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="16" Duration="0:0:0.05"/>
                                        <DoubleAnimation Storyboard.TargetName="kbGlow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="kbScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="kbScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="kbGlow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="kbGlow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="KbKeyWide"  TargetType="Button" BasedOn="{StaticResource KbKey}">
        <Setter Property="Width" Value="80"/>
    </Style>
    <Style x:Key="KbKeySpace" TargetType="Button" BasedOn="{StaticResource KbKey}">
        <Setter Property="Width" Value="148"/>
    </Style>

    <!-- ══════════════════════════════════════════════════════════
         CONTROL BAR BUTTONS — Dark gradient, colored glow
         ══════════════════════════════════════════════════════════ -->
    <Style x:Key="CtrlBtn" TargetType="Button">
        <Setter Property="FontFamily"  Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Foreground"  Value="#CBD5E1"/>
        <Setter Property="Height"      Value="50"/>
        <Setter Property="Margin"      Value="4,0"/>
        <Setter Property="Padding"     Value="14,0"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" CornerRadius="6" BorderThickness="1"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop x:Name="g1" Color="#1E293B" Offset="0"/>
                                <GradientStop x:Name="g2" Color="#0F172A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush x:Name="ctrlBorder" Color="#334155"/>
                        </Border.BorderBrush>
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="ctrlScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect x:Name="ctrlGlow" Color="#22D3EE"
                                              ShadowDepth="0" BlurRadius="0" Opacity="0"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="ctrlBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#22D3EE" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="ctrlGlow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="10" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="ctrlGlow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.6" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="ctrlBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#334155" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ctrlGlow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="ctrlGlow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ctrlScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.95" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="ctrlScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.95" Duration="0:0:0.06"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ctrlScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="ctrlScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── CONTROL TOGGLE (REPEAT / VOCAL) ── -->
    <Style x:Key="CtrlToggle" TargetType="ToggleButton">
        <Setter Property="FontFamily"  Value="{StaticResource AppFont}"/>
        <Setter Property="FontSize"    Value="11"/>
        <Setter Property="FontWeight"  Value="Bold"/>
        <Setter Property="Foreground"  Value="#CBD5E1"/>
        <Setter Property="Height"      Value="50"/>
        <Setter Property="Margin"      Value="4,0"/>
        <Setter Property="Padding"     Value="14,0"/>
        <Setter Property="Cursor"      Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="bd" CornerRadius="6" BorderThickness="1"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#1E293B" Offset="0"/>
                                <GradientStop Color="#0F172A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.BorderBrush>
                            <SolidColorBrush x:Name="togBorder" Color="#334155"/>
                        </Border.BorderBrush>
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="togScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Border.Effect>
                            <DropShadowEffect x:Name="togGlow" Color="#22D3EE"
                                              ShadowDepth="0" BlurRadius="0" Opacity="0"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource CyanBrush}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="togBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#22D3EE" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="togGlow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="8" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="togGlow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.5" Duration="0:0:0"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="togBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#334155" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="togGlow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="0" Duration="0:0:0"/>
                                        <DoubleAnimation Storyboard.TargetName="togGlow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="togBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#22D3EE" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="togGlow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="10" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="togGlow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.6" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="togBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#334155" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="togGlow"
                                                         Storyboard.TargetProperty="BlurRadius"
                                                         To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="togGlow"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="togScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="0.95" Duration="0:0:0.06"/>
                                        <DoubleAnimation Storyboard.TargetName="togScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="0.95" Duration="0:0:0.06"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="togScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetName="togScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

