<Window x:Class="KaraokeApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="🎤 Karaoke Player"
        MinWidth="1000" MinHeight="660"
        WindowState="Maximized"
        WindowStyle="None"
        ResizeMode="NoResize"
		Topmost="True"
        Closing="Window_Closing">

    <!-- Dark gradient background -->
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#080D1A" Offset="0"/>
            <GradientStop Color="#0F1A35" Offset="0.5"/>
            <GradientStop Color="#14103A" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>   <!-- Category bar     -->
            <RowDefinition Height="*"/>    <!-- Main content     -->
            <RowDefinition Height="6"/>    <!-- Progress bar     -->
            <RowDefinition Height="66"/>   <!-- Control bar      -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             ROW 0 — CATEGORY BAR
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                BorderBrush="#1E3A5F"
                BorderThickness="0,0,0,1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0A1020" Offset="0"/>
                    <GradientStop Color="#060D1C" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="44"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="❮" Style="{StaticResource NavBtn}"
                        Foreground="#22D3EE"
                        Click="BtnCategoryScrollLeft_Click"/>
                <ScrollViewer Grid.Column="1" x:Name="CategoryScrollViewer"
                              HorizontalScrollBarVisibility="Hidden"
                              VerticalScrollBarVisibility="Disabled"
                              VerticalAlignment="Center">
                    <WrapPanel x:Name="CategoryButtonPanel" Orientation="Horizontal"
                               HorizontalAlignment="Center" Margin="0,8"/>
                </ScrollViewer>
                <Button Grid.Column="2" Content="❯" Style="{StaticResource NavBtn}"
                        Foreground="#22D3EE"
                        Click="BtnCategoryScrollRight_Click"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             ROW 1 — MAIN CONTENT
             ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" MinWidth="380"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="2.2*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="#1E3A5F" Cursor="SizeWE"/>

            <!-- ╔══════════════════════════╗
                 ║  LEFT: Song list + KBD   ║
                 ╚══════════════════════════╝ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>   <!-- Tab strip -->
                    <RowDefinition Height="*"/>    <!-- Song list -->
                    <RowDefinition Height="44"/>   <!-- Search    -->
                    <RowDefinition Height="Auto"/> <!-- Keyboard  -->
                </Grid.RowDefinitions>

                <!-- Tab Strip -->
                <Border Grid.Row="0" Background="#0A1020"
                        BorderBrush="#1E3A5F" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" Margin="8,0">
                        <ToggleButton x:Name="BtnTabMyComputer" Content="MY COMPUTER"
                                      Style="{StaticResource TabBtn}" IsChecked="True"
                                      Click="BtnTabMyComputer_Click"/>
                        <ToggleButton x:Name="BtnTabYoutube" Content="YOUTUBE"
                                      Style="{StaticResource TabBtn}" IsChecked="False"
                                      Click="BtnTabYoutube_Click"/>
                    </StackPanel>
                </Border>

                <!-- Song list with rich cell template -->
                <ListView x:Name="SongListView" Grid.Row="1"
                          SelectionMode="Single"
                          MouseDoubleClick="SongList_DoubleClick"
                          KeyDown="SongList_KeyDown">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="TITLE / ARTIST" Width="340">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,3">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="#F8FAFC"
                                                       FontWeight="Bold" FontSize="13"/>
                                            <TextBlock Text="{Binding Artist}"
                                                       Foreground="#64748B"
                                                       FontSize="11" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="CATEGORY" Width="100"
                                            DisplayMemberBinding="{Binding CategoryName}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- YouTube panel -->
                <Grid x:Name="YoutubePanelGrid" Grid.Row="1" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#0A1020"
                            BorderBrush="#1E3A5F" BorderThickness="0,0,0,1">
                        <Grid Margin="6,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="YoutubeSearchBox" Grid.Column="0"
                                     Style="{StaticResource SearchBox}" Margin="0,0,6,0"
                                     KeyDown="YoutubeSearchBox_KeyDown"/>
                            <Button Grid.Column="1" Content="🔍 SEARCH" Height="32"
                                    Margin="0,0,4,0" Click="BtnYoutubeSearch_Click"
                                    Foreground="#22D3EE"/>
                            <Button Grid.Column="2" Content="📚 SAVED" Height="32"
                                    Click="BtnYoutubeLibrary_Click"/>
                        </Grid>
                    </Border>
                    <ListView x:Name="YoutubeListView" Grid.Row="1"
                              MouseDoubleClick="YoutubeList_DoubleClick"
                              KeyDown="YoutubeList_KeyDown">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="TITLE / CHANNEL" Width="500">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,3">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="#F8FAFC"
                                                           FontWeight="Bold" FontSize="13"/>
                                                <TextBlock Text="{Binding Artist}"
                                                           Foreground="#64748B"
                                                           FontSize="11" Margin="0,1,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                    </ListView>
                    <Border x:Name="YoutubeLoadingOverlay" Grid.Row="1"
                            Background="#CC0D1626" Visibility="Collapsed">
                        <TextBlock Text="⏳  Searching YouTube..."
                                   Foreground="#22D3EE" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>

                <!-- Search Bar -->
                <Border Grid.Row="2" Background="#0A1020"
                        BorderBrush="#1E3A5F" BorderThickness="0,1,0,0">
                    <Grid Margin="6,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="76"/>
                            <ColumnDefinition Width="76"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox" Grid.Column="0"
                                 Style="{StaticResource SearchBox}"
                                 Margin="0,0,6,0"
                                 TextChanged="SearchBox_TextChanged"
                                 GotFocus="SearchBox_GotFocus"/>
                        <ToggleButton x:Name="BtnSearchByTitle" Grid.Column="1"
                                      Content="TITLE" IsChecked="True"
                                      Height="32" Margin="0,0,3,0"
                                      Click="SearchMode_Click"/>
                        <ToggleButton x:Name="BtnSearchByArtist" Grid.Column="2"
                                      Content="ARTIST" IsChecked="False"
                                      Height="32" Click="SearchMode_Click"/>
                    </Grid>
                </Border>

                <!-- On-Screen Keyboard -->
                <Border x:Name="KeyboardBorder" Grid.Row="3"
                        Background="#060C18"
                        BorderBrush="#1E3A5F" BorderThickness="0,1,0,0"
                        Padding="6,8">
                    <StackPanel>
                        <WrapPanel x:Name="KbRow1" HorizontalAlignment="Center" Margin="0,2"/>
                        <WrapPanel x:Name="KbRow2" HorizontalAlignment="Center" Margin="0,2"/>
                        <WrapPanel x:Name="KbRow3" HorizontalAlignment="Center" Margin="0,2"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ╔═══════════════════════════╗
                 ║  RIGHT: Playlist + Video  ║
                 ╚═══════════════════════════╝ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>    <!-- Playlist toolbar   -->
                    <RowDefinition Height="180"/>   <!-- Playlist list      -->
                    <RowDefinition Height="52"/>    <!-- NOW PLAYING banner -->
                    <RowDefinition Height="*"/>     <!-- Video (main focus) -->
                </Grid.RowDefinitions>

                <!-- Playlist toolbar -->
                <Border Grid.Row="0" Background="#0A1020"
                        BorderBrush="#1E3A5F" BorderThickness="0,0,0,1">
                    <Grid Margin="6,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="▲" Width="34" Height="30"
                                Margin="0,0,3,0" Click="BtnPlaylistUp_Click"/>
                        <Button Grid.Column="1" Content="▼" Width="34" Height="30"
                                Click="BtnPlaylistDown_Click"/>
                        <TextBlock Grid.Column="2"
                                   Text="QUEUE" Foreground="#64748B"
                                   FontWeight="Bold" FontSize="10"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                        <Button Grid.Column="3" Content="+ INSERT"
                                Style="{StaticResource InsertBtn}"
                                Height="30" Padding="10,0" Margin="0,0,4,0"
                                Click="BtnPlaylistInsert_Click"
                                ToolTip="Add selected song to queue"/>
                        <Button Grid.Column="4" Content="✕ DELETE"
                                Style="{StaticResource DangerBtn}"
                                Height="30" Padding="10,0"
                                Click="BtnPlaylistDelete_Click"/>
                    </Grid>
                </Border>

                <!-- Playlist -->
                <ListView x:Name="PlaylistView" Grid.Row="1"
                          SelectionMode="Single"
                          MouseDoubleClick="Playlist_DoubleClick"
                          KeyDown="Playlist_KeyDown">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="UP NEXT" Width="400">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,2">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="#F8FAFC"
                                                       FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="{Binding Artist}"
                                                       Foreground="#64748B"
                                                       FontSize="10" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- NOW PLAYING banner — glowing display -->
                <Border Grid.Row="2">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#050B1A" Offset="0"/>
                            <GradientStop Color="#0A1830" Offset="0.5"/>
                            <GradientStop Color="#050B1A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border x:Name="NowPlayingBorder"
                            BorderThickness="0,1,0,1"
                            BorderBrush="#1E3A5F"
                            Padding="12,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <!-- Pulsing dot when playing -->
                            <Border Grid.Column="0" Width="8" Height="8"
                                    x:Name="PlayingDot"
                                    Background="#22D3EE" CornerRadius="4"
                                    Margin="0,0,8,0" VerticalAlignment="Center"
                                    Visibility="Collapsed">
                                <Border.Effect>
                                    <DropShadowEffect Color="#22D3EE" ShadowDepth="0"
                                                      BlurRadius="8" Opacity="1"/>
                                </Border.Effect>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation
                                                    Storyboard.TargetProperty="Opacity"
                                                    From="1" To="0.2"
                                                    Duration="0:0:0.8"
                                                    AutoReverse="True"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="NowPlayingLabel"
                                           Text="NOW PLAYING"
                                           Foreground="#22D3EE"
                                           FontSize="8" FontWeight="Bold"
                                           Visibility="Collapsed"/>
                                <TextBlock x:Name="NowPlayingText"
                                           Text="No song playing"
                                           Foreground="#94A3B8"
                                           FontSize="13" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="NowPlayingArtist"
                                           Text=""
                                           Foreground="#475569"
                                           FontSize="10"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,1,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Border>

                <!-- VIDEO AREA — the main star -->
                <Grid Grid.Row="3" Background="Black">
                    <Grid.Effect>
                        <DropShadowEffect Color="#22D3EE" ShadowDepth="0"
                                          BlurRadius="0" Opacity="0"
                                          x:Name="VideoGlow"/>
                    </Grid.Effect>
                    <vlc:VideoView x:Name="VideoView" Background="Black"/>
                    <wv2:WebView2  x:Name="YoutubeWebView" Visibility="Collapsed"/>

                    <!-- Idle screen -->
                    <StackPanel x:Name="VideoPlaceholder"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <!-- Microphone icon made with shapes -->
                        <Border Width="80" Height="80" CornerRadius="40"
                                HorizontalAlignment="Center" Margin="0,0,0,12">
                            <Border.Background>
                                <RadialGradientBrush>
                                    <GradientStop Color="#1E3A5F" Offset="0"/>
                                    <GradientStop Color="#0A1626" Offset="1"/>
                                </RadialGradientBrush>
                            </Border.Background>
                            <Border.Effect>
                                <DropShadowEffect Color="#22D3EE" ShadowDepth="0"
                                                  BlurRadius="20" Opacity="0.3"/>
                            </Border.Effect>
                            <TextBlock Text="🎤" FontSize="36"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="KARAOKE PLAYER"
                                   Foreground="#22D3EE"
                                   FontSize="16" FontWeight="ExtraBold"
                                   HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#22D3EE" ShadowDepth="0"
                                                  BlurRadius="12" Opacity="0.6"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="Select a song and press INSERT or double-click to sing"
                                   Foreground="#334155"
                                   FontSize="11" HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- Time overlay (bottom-right of video) -->
                    <TextBlock x:Name="VideoTimeDisplay"
                               Text="0:00 / 0:00"
                               Foreground="#64748B"
                               FontSize="10" FontFamily="Consolas"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Margin="0,0,8,6"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════
             ROW 2 — SONG PROGRESS BAR (neon thin strip)
             ═══════════════════════════════════════════════════════ -->
        <ProgressBar x:Name="SongProgress"
                     Grid.Row="2"
                     Style="{StaticResource NeonProgressBar}"
                     Minimum="0" Maximum="100" Value="0"/>

        <!-- ═══════════════════════════════════════════════════════
             ROW 3 — CONTROL BAR
             ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="3"
                BorderBrush="#1E3A5F" BorderThickness="0,1,0,0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0A0F1E" Offset="0"/>
                    <GradientStop Color="#060C18" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- SETTING  -->
                    <ColumnDefinition Width="Auto"/>   <!-- PLAY     -->
                    <ColumnDefinition Width="Auto"/>   <!-- PAUSE    -->
                    <ColumnDefinition Width="Auto"/>   <!-- NEXT     -->
                    <ColumnDefinition Width="Auto"/>   <!-- REPEAT   -->
                    <ColumnDefinition Width="Auto"/>   <!-- VOCAL    -->
                    <ColumnDefinition Width="*"/>      <!-- spacer   -->
                    <ColumnDefinition Width="210"/>    <!-- VOLUME   -->
                    <ColumnDefinition Width="210"/>    <!-- PITCH    -->
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="⚙ SETTING"
                        Style="{StaticResource CtrlBtn}" Width="100"
                        Click="BtnSetting_Click"/>

                <Button Grid.Column="1"
                        x:Name="BtnPlay"
                        Content="▶  PLAY"
                        Style="{StaticResource PlayBtn}"
                        Click="BtnPlay_Click"/>

                <Button Grid.Column="2"
                        x:Name="BtnPause"
                        Content="⏸  PAUSE"
                        Style="{StaticResource CtrlBtn}" Width="90"
                        Click="BtnPause_Click"/>

                <Button Grid.Column="3"
                        Content="⏭  NEXT"
                        Style="{StaticResource CtrlBtn}" Width="80"
                        Click="BtnNext_Click"/>

                <ToggleButton Grid.Column="4"
                              x:Name="BtnRepeat"
                              Content="🔁  REPEAT"
                              Style="{StaticResource CtrlToggle}" Width="95"
                              Checked="BtnRepeat_Changed"
                              Unchecked="BtnRepeat_Changed"/>

                <ToggleButton Grid.Column="5"
                              x:Name="BtnVocal"
                              Content="🎤  VOCAL"
                              Style="{StaticResource CtrlToggle}" Width="90"
                              IsChecked="False"
                              Checked="BtnVocal_Changed"
                              Unchecked="BtnVocal_Changed"/>

                <!-- VOLUME BLOCK -->
                <Border Grid.Column="7" Margin="4,6,4,6"
                        CornerRadius="6" BorderThickness="1"
                        BorderBrush="#1E3A5F" Padding="8,5">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#111E35" Offset="0"/>
                            <GradientStop Color="#0D1626" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="14"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock Text="VOLUME" Foreground="#475569"
                                       FontSize="9" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="VolumeLabel" Text="100"
                                       Foreground="#22D3EE"
                                       FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#22D3EE" ShadowDepth="0"
                                                      BlurRadius="6" Opacity="0.6"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Grid>
                        <Grid Grid.Row="1" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="28"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="−"
                                    Style="{StaticResource SmallBtn}"
                                    Click="BtnVolumeDown_Click"/>
                            <Slider x:Name="VolumeSlider" Grid.Column="1"
                                    Minimum="0" Maximum="200" Value="100"
                                    SmallChange="5" LargeChange="10"
                                    Style="{StaticResource DarkSlider}"
                                    VerticalAlignment="Center" Margin="4,0"
                                    ValueChanged="VolumeSlider_ValueChanged"/>
                            <Button Grid.Column="2" Content="+"
                                    Style="{StaticResource SmallBtn}"
                                    Click="BtnVolumeUp_Click"/>
                        </Grid>
                        <Grid Grid.Row="2">
                            <TextBlock Text="🔇" FontSize="8" Foreground="#334155"
                                       HorizontalAlignment="Left"/>
                            <TextBlock Text="🔊" FontSize="8" Foreground="#334155"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- PITCH BLOCK -->
                <Border Grid.Column="8" Margin="4,6,6,6"
                        CornerRadius="6" BorderThickness="1"
                        BorderBrush="#1E3A5F" Padding="8,5">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#111E35" Offset="0"/>
                            <GradientStop Color="#0D1626" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="14"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0">
                            <TextBlock Text="PITCH (semitones)" Foreground="#475569"
                                       FontSize="9" FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="PitchLabel" Text="0"
                                       Foreground="#818CF8"
                                       FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#818CF8" ShadowDepth="0"
                                                      BlurRadius="6" Opacity="0.6"/>
                                </TextBlock.Effect>
                            </TextBlock>
                        </Grid>
                        <Grid Grid.Row="1" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="28"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="−"
                                    Style="{StaticResource SmallBtn}"
                                    Click="BtnPitchDown_Click"/>
                            <Slider x:Name="PitchSlider" Grid.Column="1"
                                    Minimum="-12" Maximum="12" Value="0"
                                    SmallChange="1" LargeChange="2"
                                    Style="{StaticResource DarkSlider}"
                                    VerticalAlignment="Center" Margin="4,0"
                                    ValueChanged="PitchSlider_ValueChanged"/>
                            <Button Grid.Column="2" Content="+"
                                    Style="{StaticResource SmallBtn}"
                                    Click="BtnPitchUp_Click"/>
                        </Grid>
                        <Grid Grid.Row="2">
                            <TextBlock Text="−12" FontSize="8" Foreground="#334155"
                                       HorizontalAlignment="Left"/>
                            <TextBlock Text="+12" FontSize="8" Foreground="#334155"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>
