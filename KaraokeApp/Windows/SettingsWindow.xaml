<Window x:Class="KaraokeApp.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings / Database"
        Width="880" Height="620"
        MinWidth="720" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="#0D1626"
        Foreground="#F8FAFC">

    <Window.Resources>
        <!-- Dark button for settings window -->
        <Style x:Key="SettingsBtn" TargetType="Button">
            <Setter Property="FontFamily"      Value="Segoe UI"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Foreground"      Value="#CBD5E1"/>
            <Setter Property="Background"      Value="#1E293B"/>
            <Setter Property="BorderBrush"     Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="12,5"/>
            <Setter Property="Height"          Value="32"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D3F5F"/>
                                <Setter Property="BorderBrush" Value="#22D3EE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F172A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerSettingsBtn" TargetType="Button" BasedOn="{StaticResource SettingsBtn}">
            <Setter Property="Foreground"  Value="#FCA5A5"/>
            <Setter Property="Background"  Value="#2D1515"/>
            <Setter Property="BorderBrush" Value="#7F1D1D"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#3D1010"/>
                    <Setter Property="BorderBrush" Value="#F87171"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ExitSettingsBtn" TargetType="Button" BasedOn="{StaticResource SettingsBtn}">
            <Setter Property="Foreground"  Value="#FCA5A5"/>
            <Setter Property="Background"  Value="#2D1515"/>
            <Setter Property="BorderBrush" Value="#7F1D1D"/>
            <Setter Property="Width"       Value="140"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background"  Value="#3D1010"/>
                    <Setter Property="BorderBrush" Value="#F87171"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Dark TextBox -->
        <Style x:Key="DarkTextBox" TargetType="TextBox">
            <Setter Property="Background"             Value="#111E35"/>
            <Setter Property="Foreground"             Value="#F8FAFC"/>
            <Setter Property="BorderBrush"            Value="#1E3A5F"/>
            <Setter Property="BorderThickness"        Value="1"/>
            <Setter Property="Padding"                Value="8,5"/>
            <Setter Property="Height"                 Value="32"/>
            <Setter Property="FontFamily"             Value="Segoe UI"/>
            <Setter Property="FontSize"               Value="13"/>
            <Setter Property="CaretBrush"             Value="#22D3EE"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#22D3EE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Dark ComboBox -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background"   Value="#111E35"/>
            <Setter Property="Foreground"   Value="#F8FAFC"/>
            <Setter Property="BorderBrush"  Value="#1E3A5F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"      Value="8,4"/>
            <Setter Property="Height"       Value="32"/>
            <Setter Property="FontFamily"   Value="Segoe UI"/>
            <Setter Property="FontSize"     Value="13"/>
        </Style>

        <!-- Dark TabControl -->
        <Style TargetType="TabControl">
            <Setter Property="Background"  Value="#0D1626"/>
            <Setter Property="BorderBrush" Value="#1E3A5F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"     Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Foreground"  Value="#64748B"/>
            <Setter Property="Background"  Value="#0A1020"/>
            <Setter Property="BorderBrush" Value="#1E3A5F"/>
            <Setter Property="Padding"     Value="16,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tabBd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBd" Property="Background" Value="#0D1626"/>
                                <Setter TargetName="tabBd" Property="BorderBrush" Value="#22D3EE"/>
                                <Setter Property="Foreground" Value="#22D3EE"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid rows -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="#0D1626"/>
            <Setter Property="RowBackground"            Value="#0D1626"/>
            <Setter Property="AlternatingRowBackground" Value="#111E35"/>
            <Setter Property="Foreground"               Value="#CBD5E1"/>
            <Setter Property="BorderBrush"              Value="#1E3A5F"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#1E3A5F"/>
            <Setter Property="FontFamily"               Value="Segoe UI"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="RowHeight"                Value="34"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="SelectionMode"            Value="Single"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#0A1020"/>
            <Setter Property="Foreground"      Value="#64748B"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="10"/>
            <Setter Property="Padding"         Value="10,6"/>
            <Setter Property="BorderBrush"     Value="#1E3A5F"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Height"          Value="30"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0D2547"/>
                    <Setter Property="Foreground" Value="#F8FAFC"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A2744"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- GroupBox -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground"  Value="#94A3B8"/>
            <Setter Property="BorderBrush" Value="#1E3A5F"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="12"/>
            <Setter Property="Margin"      Value="0,8,0,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="8,8,8,0">

            <!-- ══════════════ SONGS ══════════════ -->
            <TabItem Header="  Songs  ">
                <Grid Background="#0D1626">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="52"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="28"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Background="#0A1020"
                            BorderBrush="#1E3A5F" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Margin="8,8" VerticalAlignment="Center">
                            <Button x:Name="BtnAddSong"      Content="+ Add Song"      Width="100"
                                    Style="{StaticResource SettingsBtn}"
                                    Click="BtnAddSong_Click"      Margin="0,0,6,0"/>
                            <Button x:Name="BtnEditSong"     Content="✎  Edit"          Width="80"
                                    Style="{StaticResource SettingsBtn}"
                                    Click="BtnEditSong_Click"     Margin="0,0,6,0"/>
                            <Button x:Name="BtnDeleteSong"   Content="✕  Delete"        Width="80"
                                    Style="{StaticResource DangerSettingsBtn}"
                                    Click="BtnDeleteSong_Click"   Margin="0,0,16,0"/>
                            <Button x:Name="BtnImportFolder" Content="📁  Import Folder" Width="140"
                                    Style="{StaticResource SettingsBtn}"
                                    Click="BtnImportFolder_Click" Margin="0,0,16,0"/>
                            <TextBox x:Name="TxtSongSearch" Width="220"
                                     Style="{StaticResource DarkTextBox}"
                                     TextChanged="TxtSongSearch_TextChanged"/>
                        </StackPanel>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid x:Name="SongGrid" Grid.Row="1" Margin="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"         Binding="{Binding Id}"
                                                Width="44"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Title"      Binding="{Binding Title}"
                                                Width="180"/>
                            <DataGridTextColumn Header="Artist"     Binding="{Binding Artist}"
                                                Width="140"/>
                            <DataGridTextColumn Header="Category"   Binding="{Binding CategoryName}"
                                                Width="90"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Type"       Binding="{Binding SourceType}"
                                                Width="55"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Date Added"
                                                Binding="{Binding DateAdded, StringFormat=\{0:yyyy-MM-dd\}}"
                                                Width="95"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="File Path"  Binding="{Binding FilePath}"
                                                Width="*"   IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Status bar -->
                    <Border Grid.Row="2" Background="#0A1020"
                            BorderBrush="#1E3A5F" BorderThickness="0,1,0,0">
                        <TextBlock x:Name="TxtSongCount"
                                   Text="0 song(s)"
                                   Foreground="#475569"
                                   FontSize="11"
                                   Margin="10,0"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══════════════ CATEGORIES ══════════════ -->
            <TabItem Header="  Categories  ">
                <Grid Background="#0D1626">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="52"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#0A1020"
                            BorderBrush="#1E3A5F" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Margin="8,8" VerticalAlignment="Center">
                            <Button x:Name="BtnAddCategory"    Content="+ Add"    Width="80"
                                    Style="{StaticResource SettingsBtn}"
                                    Click="BtnAddCategory_Click"    Margin="0,0,6,0"/>
                            <Button x:Name="BtnEditCategory"   Content="✎  Edit"   Width="80"
                                    Style="{StaticResource SettingsBtn}"
                                    Click="BtnEditCategory_Click"   Margin="0,0,6,0"/>
                            <Button x:Name="BtnDeleteCategory" Content="✕  Delete" Width="80"
                                    Style="{StaticResource DangerSettingsBtn}"
                                    Click="BtnDeleteCategory_Click"/>
                        </StackPanel>
                    </Border>

                    <DataGrid x:Name="CategoryGrid" Grid.Row="1" Margin="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID"       Binding="{Binding Id}"       Width="50"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Name"     Binding="{Binding Name}"     Width="150"/>
                            <DataGridTextColumn Header="Keywords (comma-separated match words)" Binding="{Binding Keywords}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2" Background="#0A1020"
                            BorderBrush="#1E3A5F" BorderThickness="0,1,0,0"
                            Padding="10,8">
                        <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#475569">
                            Keywords are comma-separated tokens matched during filename import.
                            e.g.  Name: English  |  Keywords: english,inggris,barat,western
                        </TextBlock>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══════════════ IMPORT SETTINGS ══════════════ -->
            <TabItem Header="  Import Settings  ">
                <ScrollViewer Background="#0D1626">
                    <StackPanel Margin="20">
                        <TextBlock Text="Filename Parsing" Foreground="#22D3EE"
                                   FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#64748B"
                                   FontSize="12" Margin="0,0,0,12">
                            Filenames are split into fields using the separator below.
                            Format:  TITLE # ARTIST # CATEGORY_KEYWORD # VOCAL_HINT
                        </TextBlock>

                        <TextBlock Text="Example:" Foreground="#94A3B8"
                                   FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <Border Background="#111E35" CornerRadius="4" Padding="12,8" Margin="0,0,0,6">
                            <TextBlock Foreground="#22D3EE" FontFamily="Consolas" FontSize="12"
                                       Text="PERFECT#ED SHEERAN FT BEYONCE#BARAT#LEFT.dat"/>
                        </Border>
                        <TextBlock Foreground="#475569" FontSize="11" Margin="0,0,0,16">
                            → Title: PERFECT  |  Artist: ED SHEERAN FT BEYONCE  |  Category: English (via "BARAT")
                        </TextBlock>

                        <Grid Margin="0,0,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Separator character:"
                                       Foreground="#94A3B8" VerticalAlignment="Center"
                                       FontWeight="SemiBold"/>
                            <TextBox   Grid.Column="1" x:Name="TxtSeparator"
                                       Style="{StaticResource DarkTextBox}"
                                       MaxLength="5" Margin="0,0,10,0"/>
                            <Button    Grid.Column="2" Content="Save"
                                       Style="{StaticResource SettingsBtn}"
                                       Width="100" Click="BtnSaveSeparator_Click"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ══════════════ YOUTUBE ══════════════ -->
            <TabItem Header="  YouTube  ">
                <ScrollViewer Background="#0D1626">
                    <StackPanel Margin="20">
                        <TextBlock Text="YouTube Data API v3 Key" Foreground="#22D3EE"
                                   FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#64748B"
                                   FontSize="12" Margin="0,0,0,12">
                            Get a free key at console.cloud.google.com → enable "YouTube Data API v3".
                        </TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtYoutubeApiKey" Grid.Column="0"
                                     Style="{StaticResource DarkTextBox}" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Save"
                                    Style="{StaticResource SettingsBtn}"
                                    Click="BtnSaveApiKey_Click"/>
                        </Grid>

                        <TextBlock Margin="0,24,0,8" Foreground="#22D3EE"
                                   FontWeight="Bold" FontSize="14"
                                   Text="Add YouTube Song Manually"/>
                        <Border Background="#111E35" CornerRadius="6" Padding="16" BorderBrush="#1E3A5F" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="YouTube URL:"
                                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="TxtManualUrl"
                                           Style="{StaticResource DarkTextBox}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Title:"
                                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBox   Grid.Row="1" Grid.Column="1" x:Name="TxtManualTitle"
                                           Style="{StaticResource DarkTextBox}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Artist:"
                                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="TxtManualArtist"
                                           Style="{StaticResource DarkTextBox}" Margin="0,0,0,8"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Category:"
                                           Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,0,8"/>
                                <ComboBox  Grid.Row="3" Grid.Column="1" x:Name="CmbManualCategory"
                                           Style="{StaticResource DarkComboBox}"
                                           DisplayMemberPath="Name" SelectedValuePath="Id"
                                           Margin="0,0,0,8"/>
                                <Button    Grid.Row="4" Grid.Column="1" Content="+ Add to Library"
                                           HorizontalAlignment="Left" Width="140"
                                           Style="{StaticResource SettingsBtn}"
                                           Click="BtnAddManualYoutube_Click"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- Bottom bar -->
        <Border Grid.Row="1" Background="#0A1020"
                BorderBrush="#1E3A5F" BorderThickness="0,1,0,0">
            <DockPanel Margin="12,0">
                <Button DockPanel.Dock="Right"
                        Content="Exit Application"
                        Style="{StaticResource ExitSettingsBtn}"
                        Margin="6,0,0,0"
                        Click="BtnExitApp_Click"/>
                <Button DockPanel.Dock="Right"
                        Content="Close"
                        Style="{StaticResource SettingsBtn}"
                        Width="100"
                        Click="BtnClose_Click"/>
                <StackPanel/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
